# Managed by nix: modules/shared/shells/zsh (symlinked to the live checkout,
# so edits here apply to new shells without a rebuild).
# Machine-local/secret env vars belong in ~/.zshrc.local, sourced at the end.
stty -ixon

# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh

# Bootstrap oh-my-zsh and plugins on a fresh machine
[ -d "$ZSH" ] || git clone https://github.com/ohmyzsh/ohmyzsh.git "$ZSH"
[ -d "$ZSH/zsh-syntax-highlighting" ] || git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$ZSH/zsh-syntax-highlighting"

ZSH_THEME="gallois"

# Display red dots whilst waiting for completion.
COMPLETION_WAITING_DOTS="true"

plugins=(git osx)

source $ZSH/oh-my-zsh.sh
source ~/.oh-my-zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Aliases
alias c="clear"
alias vim="nvim"
alias coad='cd $(find ~/Code -maxdepth 3 | fzf)'
alias tidaldlx="uv --directory /Users/Jack/Code/github.com/jack-michaud/tidaldlx/ run python -m tidaldlx.cli"
alias jclaude='claude " "'
# Montana Banana pi extension
alias pimb='pi -e /Users/Jack/Code/github.com/MontanaBanana/pi-mb/.pi/extensions/montana-banana/index.ts'

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
command -v pyenv > /dev/null && eval "$(pyenv init -)"

export PATH="$PATH:$HOME/.local/bin"

# jj completions
command -v jj > /dev/null && source <(COMPLETE=zsh jj)

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Added by LM Studio CLI (lms)
export PATH="$PATH:$HOME/.lmstudio/bin"
# End of LM Studio CLI section

export PATH="$HOME/.deno/bin:$PATH"

# opencode
export PATH=$HOME/.opencode/bin:$PATH

# prompt
command -v starship > /dev/null && eval "$(starship init zsh)"

# Machine-local overrides and secret env vars (not tracked in nix config)
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
