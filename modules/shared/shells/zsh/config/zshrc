# Managed by nix: modules/shared/shells/zsh (symlinked to the live checkout,
# so edits here apply to new shells without a rebuild).
# Machine-local/secret env vars belong in ~/.zshrc.local, sourced at the end.
[[ -t 0 ]] && stty -ixon

# Dedupe PATH/fpath: nested shells inherit exported FPATH (brew shellenv
# exports it), so entries pile up and compinit rescans the same dirs.
typeset -U path fpath

# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh

# Bootstrap oh-my-zsh and plugins on a fresh machine
[ -d "$ZSH" ] || git clone https://github.com/ohmyzsh/ohmyzsh.git "$ZSH"
[ -d "$ZSH/zsh-syntax-highlighting" ] || git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$ZSH/zsh-syntax-highlighting"

ZSH_THEME="gallois"

# Display red dots whilst waiting for completion.
COMPLETION_WAITING_DOTS="true"

plugins=(git osx)

# oh-my-zsh always runs a full compinit (rescans every fpath dir). Shadow it:
# trust the cached dump (-C) unless it's missing or older than a day.
compinit() {
  unfunction compinit
  autoload -Uz compinit
  local dump="${ZSH_COMPDUMP:-$HOME/.zcompdump}"
  if [[ -n "$dump"(#qN.mh-24) ]]; then
    compinit -C -d "$dump"
  else
    compinit -i -d "$dump"
    touch "$dump"
  fi
}

source $ZSH/oh-my-zsh.sh
source ~/.oh-my-zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Aliases
alias c="clear"
alias vim="nvim"
alias coad='cd $(find ~/Code -maxdepth 3 | fzf)'
alias tidaldlx="uv --directory /Users/Jack/Code/github.com/jack-michaud/tidaldlx/ run python -m tidaldlx.cli"
alias jclaude='claude " "'
# Montana Banana pi extension
alias pimb='pi -e /Users/Jack/Code/github.com/MontanaBanana/pi-mb/.pi/extensions/montana-banana/index.ts'

# Cache `<tool> init`-style output; spawning the tool on every shell is slow.
# Regenerates when the tool's binary is newer than the cache.
_cache_init() {  # usage: _cache_init <name> <bin> <command...>
  local cache="$HOME/.cache/zsh/$1.zsh"
  if [[ ! -s "$cache" || "$commands[$2]" -nt "$cache" ]]; then
    mkdir -p "$HOME/.cache/zsh"
    "${@:3}" > "$cache"
  fi
  source "$cache"
}

# nvm: sourcing nvm.sh costs ~300ms, so put the default node on PATH directly
# and load the real nvm only on first use.
export NVM_DIR="$HOME/.nvm"
if [[ -r "$NVM_DIR/alias/default" && -d "$NVM_DIR/versions/node/$(<$NVM_DIR/alias/default)/bin" ]]; then
  path=("$NVM_DIR/versions/node/$(<$NVM_DIR/alias/default)/bin" $path)
  nvm() {
    unfunction nvm
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    nvm "$@"
  }
else
  # default alias isn't a plain version dir (e.g. lts/*) — eager load so node
  # is still on PATH.
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
fi

# pyenv: `pyenv init` spawns bash + `pyenv rehash` on every shell (~90ms).
# Shims on PATH is all python/pip need; full init happens on first `pyenv` use.
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv > /dev/null; then
  path=("$PYENV_ROOT/shims" $path)
  export PYENV_SHELL=zsh
  pyenv() {
    unfunction pyenv
    eval "$(command pyenv init - zsh)"
    pyenv "$@"
  }
fi

export PATH="$PATH:$HOME/.local/bin"

# jj completions
command -v jj > /dev/null && _cache_init jj-completions jj env COMPLETE=zsh jj

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Added by LM Studio CLI (lms)
export PATH="$PATH:$HOME/.lmstudio/bin"
# End of LM Studio CLI section

export PATH="$HOME/.deno/bin:$PATH"

# opencode
export PATH=$HOME/.opencode/bin:$PATH

# prompt
command -v starship > /dev/null && _cache_init starship-init starship starship init zsh --print-full-init

# Machine-local overrides and secret env vars (not tracked in nix config)
[ -f ~/.zshrc.local ] && source ~/.zshrc.local
